# MongoDB connection string
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=MyApp

# Server port
PORT=5001

# YouTube API Keys — add as many as needed (YOUTUBE_API_KEY_1, _2, _3, etc.)
YOUTUBE_API_KEY_1=your-api-key-here
YOUTUBE_API_KEY_2=your-api-key-here

# Rotating proxy — single endpoint (recommended for production)
# Services: BrightData, Oxylabs, SmartProxy, etc.
# PROXY_URL=http://user:pass@proxy.example.com:port

# OR multiple static proxies (comma-separated, round-robin)
# PROXY_URLS=http://user:pass@proxy1:port,http://user:pass@proxy2:port

# Concurrent execution pools
MAX_BROWSERS=50
MAX_CONCURRENT_WORKERS=50

# CORS origins (comma-separated, in addition to defaults)
# CORS_ORIGINS=https://myapp.com,https://staging.myapp.com

# Node environment
NODE_ENV=production
